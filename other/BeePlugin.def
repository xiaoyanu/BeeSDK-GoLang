LIBRARY BeeGoPlugin
EXPORTS
    "Bee_插件被禁用"=bee_disable
    "Bee_插件被启用"=bee_enable
    "Bee_插件被卸载"=bee_unload
    "Bee_插件设置"=bee_settings
    "Bee_初始化"=bee_init
    "Bee_收到频道事件"=bee_channel_event
    "Bee_收到频道私信"=bee_channel_dm
    "Bee_收到频道消息"=bee_channel_msg
    "Bee_收到群聊消息"=bee_group_msg
    "Bee_收到私聊消息"=bee_private_msg
    "Bee_收到通常事件"=bee_common_event

